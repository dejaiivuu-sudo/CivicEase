// BARCODE / QR SCANNER
// ════════════════════════════════════
let scanStream=null,scanInterval=null,scanFacingMode='environment',scanDetected=false;
let scannedName='',scannedExp='';

// ZXing loaded lazily
async function loadZXing(){
  if(window.ZXing)return window.ZXing;
  return new Promise((res,rej)=>{
    const s=document.createElement('script');
    s.src='https://cdnjs.cloudflare.com/ajax/libs/zxing-js/0.20.0/umd/index.min.js';
    s.onload=()=>res(window.ZXing);
    s.onerror=()=>rej(new Error('ZXing failed to load'));
    document.head.appendChild(s);
  });
}

async function openScanner(){
  scanDetected=false;scannedName='';scannedExp='';
  document.getElementById('scan-result').style.display='none';
  document.getElementById('scan-add-btn').style.display='none';
  document.getElementById('manual-exp-row').style.display='none';
  document.getElementById('scan-status').textContent='Starting camera…';
  document.getElementById('scan-modal').classList.add('open');
  try{
    await startCamera();
  }catch(e){
    document.getElementById('scan-status').textContent='Camera not available. Enter details manually below.';
    document.getElementById('manual-exp-row').style.display='block';
    document.getElementById('scan-add-btn').style.display='block';
    document.getElementById('scan-item-name').textContent='Unknown item';
    document.getElementById('scan-exp-val').textContent='Enter manually';
    document.getElementById('scan-result').style.display='block';
    scannedName='Unknown item';
  }
}

async function startCamera(){
  if(scanStream){scanStream.getTracks().forEach(t=>t.stop());}
  const constraints={video:{facingMode:scanFacingMode,width:{ideal:1280},height:{ideal:720}}};
  scanStream=await navigator.mediaDevices.getUserMedia(constraints);
  const vid=document.getElementById('scan-video');
  vid.srcObject=scanStream;
  await vid.play();
  document.getElementById('scan-status').textContent='Scanning… point camera at barcode';
  startDecoding();
}

async function startDecoding(){
  clearInterval(scanInterval);
  let zx;
  try{ zx=await loadZXing(); }catch(e){ setScanStatus('Barcode library unavailable. Enter expiry manually.'); showManualEntry(); return; }
  const hints=new Map();
  const fmts=[zx.BarcodeFormat.EAN_13,zx.BarcodeFormat.EAN_8,zx.BarcodeFormat.CODE_128,
    zx.BarcodeFormat.CODE_39,zx.BarcodeFormat.UPC_A,zx.BarcodeFormat.UPC_E,zx.BarcodeFormat.QR_CODE,
    zx.BarcodeFormat.DATA_MATRIX,zx.BarcodeFormat.PDF_417];
  hints.set(zx.DecodeHintType.POSSIBLE_FORMATS,fmts);
  hints.set(zx.DecodeHintType.TRY_HARDER,true);
  const reader=new zx.MultiFormatReader();
  reader.setHints(hints);
  const canvas=document.getElementById('scan-canvas');
  const ctx=canvas.getContext('2d');
  scanInterval=setInterval(()=>{
    if(scanDetected)return;
    const vid=document.getElementById('scan-video');
    if(vid.readyState<2)return;
    canvas.width=vid.videoWidth;canvas.height=vid.videoHeight;
    ctx.drawImage(vid,0,0);
    try{
      const imgData=ctx.getImageData(0,0,canvas.width,canvas.height);
      const lum=new zx.RGBLuminanceSource(imgData.data,canvas.width,canvas.height);
      const bmp=new zx.BinaryBitmap(new zx.HybridBinarizer(lum));
      const result=reader.decode(bmp);
      if(result){
        scanDetected=true;
        handleScanResult(result.getText(),result.getBarcodeFormat());
      }
    }catch(e){}
  },300);
}

function handleScanResult(code, fmt){
  setScanStatus('&#10003; Code detected!');
  // Try to parse as QR with JSON data (e.g. {"name":"Milk","exp":"2025-12-01"})
  let name='',exp='';
  try{
    const parsed=JSON.parse(code);
    name=parsed.name||parsed.item||parsed.product||'';
    exp=parsed.exp||parsed.expiry||parsed.expDate||parsed.best_before||'';
    if(exp&&!/^\d{4}-\d{2}-\d{2}$/.test(exp)){exp=parseExpDate(exp);}
  }catch(e){
    // Not JSON — try to extract date pattern from raw string
    // Patterns: DD/MM/YYYY, MM/YYYY, YYYY-MM-DD, DDMMYYYY etc.
    const rawDate=extractDateFromString(code);
    if(rawDate){exp=rawDate;}
    // Try to use barcode as product lookup hint
    name=code.length>10?'Scanned Item ('+code.slice(0,8)+'…)':'Scanned Item';
  }
  scannedName=name||'Scanned Item';
  scannedExp=exp||'';
  document.getElementById('scan-item-name').textContent=scannedName;
  document.getElementById('scan-exp-val').textContent=scannedExp?formatDisplayDate(scannedExp):'Not found — enter manually';
  document.getElementById('scan-result').style.display='block';
  document.getElementById('scan-add-btn').style.display='block';
  if(!scannedExp){
    document.getElementById('manual-exp-row').style.display='block';
    const today=new Date().toISOString().split('T')[0];
    document.getElementById('scan-manual-exp').value=today;
  }
}

function extractDateFromString(str){
  // Try common date patterns
  const patterns=[
    {re:/(\d{4})-(\d{2})-(\d{2})/,fn:m=>m[0]},                      // YYYY-MM-DD
    {re:/(\d{2})\/(\d{2})\/(\d{4})/,fn:m=>`${m[3]}-${m[2]}-${m[1]}`}, // DD/MM/YYYY
    {re:/(\d{2})\/(\d{4})/,fn:m=>`${m[2]}-${m[1]}-01`},              // MM/YYYY
    {re:/(\d{2})(\d{2})(\d{4})/,fn:m=>`${m[3]}-${m[2]}-${m[1]}`},    // DDMMYYYY
    {re:/BEST BY[:\s]+(\d{2})[\/-](\d{4})/i,fn:m=>`${m[2]}-${m[1]}-01`},
    {re:/EXP[:\s]+(\d{2})[\/-](\d{2})[\/-](\d{4})/i,fn:m=>`${m[3]}-${m[2]}-${m[1]}`},
    {re:/USE BY[:\s]+(\d{2})[\/-](\d{2})[\/-](\d{4})/i,fn:m=>`${m[3]}-${m[2]}-${m[1]}`},
  ];
  for(const{re,fn}of patterns){
    const m=str.match(re);
    if(m){const d=fn(m);if(isValidDate(d))return d;}
  }
  return '';
}

function parseExpDate(str){
  if(!str)return'';
  if(/^\d{4}-\d{2}-\d{2}$/.test(str))return str;
  const m1=str.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
  if(m1)return`${m1[3]}-${m1[2]}-${m1[1]}`;
  const m2=str.match(/^(\d{2})\/(\d{4})$/);
  if(m2)return`${m2[2]}-${m2[1]}-01`;
  return str;
}

function isValidDate(d){
  const dt=new Date(d);return dt instanceof Date&&!isNaN(dt)&&dt.getFullYear()>2000&&dt.getFullYear()<2040;
}

function formatDisplayDate(d){
  try{return new Date(d+'T00:00:00').toLocaleDateString('en-JM',{year:'numeric',month:'short',day:'numeric'});}catch(e){return d;}
}

function setScanStatus(msg){document.getElementById('scan-status').innerHTML=msg;}
function showManualEntry(){
  document.getElementById('manual-exp-row').style.display='block';
  document.getElementById('scan-add-btn').style.display='block';
  document.getElementById('scan-result').style.display='block';
  document.getElementById('scan-item-name').textContent=scannedName||'Unknown item';
  document.getElementById('scan-exp-val').textContent='Not detected';
  scannedName=scannedName||'Unknown item';
}

async function toggleCamera(){
  scanFacingMode=scanFacingMode==='environment'?'user':'environment';
  scanDetected=false;
  clearInterval(scanInterval);
  document.getElementById('scan-result').style.display='none';
  document.getElementById('scan-add-btn').style.display='none';
  document.getElementById('manual-exp-row').style.display='none';
  try{await startCamera();}catch(e){setScanStatus('Could not switch camera.');}
}

function addScannedItem(){
  const nameEl=document.getElementById('scan-item-name');
  const name=nameEl.textContent==='–'||nameEl.textContent==='Unknown item'?'Scanned Item':nameEl.textContent;
  // Use manual date if provided, else scanned
  const manualEl=document.getElementById('scan-manual-exp');
  const exp=manualEl.value||scannedExp;
  if(!exp){toast('Please enter the expiry date','err');return;}
  // Pre-fill the Add Item modal
  closeScanner();
  document.getElementById('it-name').value=name;
  document.getElementById('it-exp').value=exp;
  openM('m-item');
  toast('Item detected — review and confirm below','ok');
}

function closeScanner(){
  clearInterval(scanInterval);
  if(scanStream)scanStream.getTracks().forEach(t=>t.stop());
  scanStream=null;scanDetected=false;
  document.getElementById('scan-modal').classList.remove('open');
  document.getElementById('scan-video').srcObject=null;
}

document.addEventListener('DOMContentLoaded',()=>{
  initOB();
  const today=new Date().toISOString().split('T')[0];
  ['b-due','e-date','r-date','it-exp'].forEach(id=>{const el=document.getElementById(id);if(el)el.value=today;});
});
</script>

