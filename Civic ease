<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CivicEase — Smart Living for Every Citizen</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800;900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --td:#0a4a45;--t:#0d7a72;--tm:#12a89d;--tl:#e0f5f4;
  --g:#d4a017;--gl:#f0c040;--gp:#fdf6e0;
  --r:#c0392b;--rl:#e74c3c;--rp:#fdecea;
  --wh:#fff;--sf:#f8fffe;--bd:#c8eae8;--tx:#0d2b29;--mu:#5a8a86;
  --sw:248px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--sf);color:var(--tx);display:flex;min-height:100vh;overflow-x:hidden}

/* ── ONBOARDING ── */
#ob{position:fixed;inset:0;background:linear-gradient(135deg,var(–td),var(–t),var(–tm));z-index:2000;display:flex;align-items:center;justify-content:center}
.ob-card{background:#fff;border-radius:24px;padding:38px;width:520px;max-width:95vw;max-height:93vh;overflow-y:auto;box-shadow:0 30px 80px rgba(10,74,69,.4);border-top:5px solid var(–g)}
.ob-step{display:none;animation:fi .3s}.ob-step.active{display:block}
.ob-title{font-family:‘Playfair Display’,serif;font-size:21px;font-weight:800;color:var(–td);margin-bottom:5px}
.ob-sub{font-size:13px;color:var(–mu);margin-bottom:20px}
.ob-dots{display:flex;gap:6px;margin-bottom:26px}
.od{width:8px;height:8px;border-radius:50%;background:var(–bd);transition:all .3s}
.od.active{background:var(–g);width:22px;border-radius:4px}
.od.done{background:var(–t)}
.ob-nav{display:flex;justify-content:space-between;align-items:center;margin-top:20px}
.ob-back{color:var(–mu);font-size:13px;cursor:pointer;background:none;border:none;font-family:‘Plus Jakarta Sans’,sans-serif}
.ob-back:hover{color:var(–t)}
.info-box{background:var(–tl);border-radius:11px;padding:14px 16px;margin-bottom:18px;border-left:4px solid var(–t);font-size:13px;color:var(–td);line-height:1.6}

/* ── SIDEBAR ── */
#sb{width:var(–sw);background:var(–td);display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100vh;z-index:100;border-right:2px solid rgba(212,160,23,.2)}
.sb-logo{padding:20px 20px 16px;border-bottom:1px solid rgba(255,255,255,.1);position:relative}
.sb-logo::after{content:’’;position:absolute;bottom:0;left:20px;right:20px;height:2px;background:linear-gradient(90deg,var(–g),transparent)}
.lm{display:flex;align-items:center;gap:9px}
.li{width:33px;height:33px;background:var(–g);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.lt h1{font-family:‘Playfair Display’,serif;font-size:18px;font-weight:800;color:#fff}
.lt p{font-size:10px;color:rgba(255,255,255,.4);margin-top:1px}
.ns{padding:11px 9px 3px}
.nl{font-size:9px;text-transform:uppercase;letter-spacing:1.5px;color:rgba(255,255,255,.3);padding:0 11px;margin-bottom:4px;font-weight:600}
.ni{display:flex;align-items:center;gap:10px;padding:9px 11px;border-radius:9px;cursor:pointer;transition:all .2s;color:rgba(255,255,255,.55);font-size:13px;font-weight:500;margin-bottom:1px}
.ni:hover{background:rgba(255,255,255,.08);color:#fff}
.ni.active{background:linear-gradient(135deg,var(–g),var(–gl));color:var(–td);font-weight:700;box-shadow:0 4px 14px rgba(212,160,23,.35)}
.ni .ic{font-size:16px;width:19px;text-align:center}
.sb-ft{margin-top:auto;padding:11px 9px;border-top:1px solid rgba(255,255,255,.08)}
.uc{display:flex;align-items:center;gap:10px;padding:8px 11px;border-radius:9px;background:rgba(255,255,255,.06);cursor:pointer}
.uc:hover{background:rgba(255,255,255,.1)}
.av{width:33px;height:33px;border-radius:50%;background:linear-gradient(135deg,var(–tm),var(–g));display:flex;align-items:center;justify-content:center;font-weight:700;color:#fff;font-size:12px;border:2px solid var(–g);flex-shrink:0}
.ui p{font-size:13px;color:#fff;font-weight:600}.ui span{font-size:10px;color:rgba(255,255,255,.4)}

/* ── MAIN ── */
#mn{margin-left:var(–sw);flex:1;display:flex;flex-direction:column;min-height:100vh}
.tb{background:#fff;border-bottom:1.5px solid var(–bd);padding:13px 28px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;box-shadow:0 1px 10px rgba(13,122,114,.06)}
.tb-t{font-family:‘Playfair Display’,serif;font-size:19px;font-weight:800;color:var(–td)}
.tb-s{font-size:12px;color:var(–mu);margin-top:1px}
.db{background:var(–tl);border:1px solid var(–bd);padding:5px 13px;border-radius:20px;font-size:12px;color:var(–t);font-weight:600}
.pc{padding:22px 28px;flex:1}

/* ── PAGES ── */
.pg{display:none;animation:fi .3s}.pg.active{display:block}
#pg-chat.active{display:flex}
@keyframes fi{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}}

/* ── CARDS ── */
.card{background:#fff;border:1.5px solid var(–bd);border-radius:16px;padding:20px;box-shadow:0 2px 10px rgba(13,122,114,.05)}
.ct{font-family:‘Playfair Display’,serif;font-size:15px;font-weight:700;color:var(–td);margin-bottom:3px}
.cs{font-size:12px;color:var(–mu);margin-bottom:14px}

/* ── GRID ── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}

/* ── STAT CARDS ── */
.sc{border-radius:15px;padding:17px;color:#fff;position:relative;overflow:hidden}
.sc::before{content:’’;position:absolute;right:-18px;top:-18px;width:70px;height:70px;border-radius:50%;background:rgba(255,255,255,.1)}
.sl{font-size:11px;opacity:.85;margin-bottom:4px;font-weight:600;letter-spacing:.3px}
.sv{font-family:‘Playfair Display’,serif;font-size:22px;font-weight:900}
.sch{font-size:11px;margin-top:4px;opacity:.85}
.bg-t{background:linear-gradient(135deg,var(–td),var(–tm))}
.bg-g{background:linear-gradient(135deg,#a07010,var(–gl));color:var(–td)!important}
.bg-g .sl,.bg-g .sch{color:var(–td)!important;opacity:.7}
.bg-r{background:linear-gradient(135deg,#8b1a12,var(–rl))}
.bg-t2{background:linear-gradient(135deg,var(–t),#1ecec3)}

/* ── BUTTONS ── */
.btn{padding:9px 17px;border-radius:9px;border:none;cursor:pointer;font-family:‘Plus Jakarta Sans’,sans-serif;font-size:13px;font-weight:600;transition:all .2s}
.bp{background:var(–t);color:#fff}.bp:hover{background:var(–td);box-shadow:0 4px 12px rgba(13,122,114,.3)}
.bg2{background:var(–g);color:var(–td)}.bg2:hover{background:var(–gl)}
.bo{background:transparent;border:1.5px solid var(–bd);color:var(–tx)}.bo:hover{border-color:var(–t);color:var(–t)}
.bd2{background:var(–rp);color:var(–r);border:none}.bd2:hover{background:#fad7d4}
.bsm{padding:6px 12px;font-size:12px}
.bfl{width:100%}

/* ── FORMS ── */
.fg{margin-bottom:13px}
.fg label{display:block;font-size:11px;font-weight:700;color:var(–mu);text-transform:uppercase;letter-spacing:.6px;margin-bottom:5px}
.fg input,.fg select,.fg textarea{width:100%;padding:9px 13px;border:1.5px solid var(–bd);border-radius:9px;font-family:‘Plus Jakarta Sans’,sans-serif;font-size:13.5px;color:var(–tx);background:#fff;outline:none;transition:border-color .2s}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(–t);box-shadow:0 0 0 3px rgba(13,122,114,.08)}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:11px}
.fg textarea{min-height:72px;resize:vertical}

/* ── TAGS ── */
.tag{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700}
.tg{background:var(–tl);color:var(–td)}.tr{background:var(–rp);color:var(–r)}
.ty{background:var(–gp);color:#7a5800}.tt{background:var(–tl);color:var(–t)}
.tk{background:#f0f4f4;color:#5a8a86}

/* ── PROGRESS ── */
.pb{height:7px;background:var(–tl);border-radius:99px;overflow:hidden}
.pf{height:100%;border-radius:99px;transition:width .6s}

/* ── LISTS ── */
.li2{display:flex;align-items:center;gap:11px;padding:11px 0;border-bottom:1px solid var(–bd)}
.li2:last-child{border-bottom:none}
.lic{width:37px;height:37px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.lif{flex:1;min-width:0}
.lif strong{display:block;font-size:13.5px;color:var(–tx);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.lif span{font-size:11.5px;color:var(–mu)}
.lam{font-family:‘Playfair Display’,serif;font-weight:700;font-size:14px;white-space:nowrap}

/* ── MODAL ── */
.mo{position:fixed;inset:0;background:rgba(10,74,69,.45);z-index:500;display:none;align-items:center;justify-content:center;backdrop-filter:blur(5px)}
.mo.open{display:flex}
.md{background:#fff;border-radius:20px;padding:24px;width:460px;max-width:95vw;max-height:88vh;overflow-y:auto;animation:mi .25s;border-top:4px solid var(–g);box-shadow:0 20px 60px rgba(10,74,69,.25)}
@keyframes mi{from{opacity:0;transform:scale(.94)}to{opacity:1;transform:scale(1)}}
.mh{display:flex;justify-content:space-between;align-items:center;margin-bottom:17px}
.mt{font-family:‘Playfair Display’,serif;font-size:18px;font-weight:800;color:var(–td)}
.mc{width:27px;height:27px;border-radius:50%;border:none;background:var(–tl);color:var(–t);cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;font-weight:700}
.mf{display:flex;gap:8px;justify-content:flex-end;margin-top:17px}

/* ── TOAST ── */
#toast{position:fixed;bottom:24px;right:24px;background:var(–td);color:#fff;padding:12px 17px;border-radius:10px;font-size:13px;z-index:999;opacity:0;transform:translateY(10px);transition:all .3s;pointer-events:none;max-width:290px;border-left:4px solid var(–g);font-weight:500}
#toast.show{opacity:1;transform:translateY(0)}
#toast.err{background:var(–r);border-left-color:#fff}
#toast.ok{border-left-color:var(–gl)}

/* ── DASHBOARD BANNER ── */
.wb{background:linear-gradient(135deg,var(–td) 0%,var(–t) 55%,var(–tm) 100%);border-radius:17px;padding:24px 26px;color:#fff;margin-bottom:19px;position:relative;overflow:hidden;border-bottom:3px solid var(–g)}
.wb::before{content:’’;position:absolute;right:-40px;top:-40px;width:200px;height:200px;border-radius:50%;background:rgba(212,160,23,.1)}
.wb h2{font-family:‘Playfair Display’,serif;font-size:21px;font-weight:900;margin-bottom:5px}
.wb p{font-size:13px;opacity:.8;max-width:480px}
.qa{display:flex;gap:8px;margin-top:15px;flex-wrap:wrap}
.qb{padding:7px 14px;border-radius:20px;background:rgba(255,255,255,.13);color:#fff;border:1px solid rgba(255,255,255,.25);cursor:pointer;font-size:12px;font-family:‘Plus Jakarta Sans’,sans-serif;font-weight:500;transition:all .2s}
.qb:hover{background:rgba(212,160,23,.3);border-color:var(–gl)}

/* ── CHAT ── */
#pg-chat{height:calc(100vh - 120px);flex-direction:column}
.cm{flex:1;overflow-y:auto;padding:14px 0;display:flex;flex-direction:column;gap:12px}
.msg{display:flex;gap:10px;align-items:flex-start;max-width:78%}
.msg.user{align-self:flex-end;flex-direction:row-reverse}
.mav{width:31px;height:31px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.mb{padding:10px 14px;border-radius:14px;font-size:13.5px;line-height:1.6}
.msg.bot .mav{background:var(–td)}.msg.bot .mb{background:#fff;border:1.5px solid var(–bd);color:var(–tx);border-radius:4px 14px 14px 14px}
.msg.user .mav{background:var(–g)}.msg.user .mb{background:linear-gradient(135deg,var(–t),var(–tm));color:#fff;border-radius:14px 4px 14px 14px}
.cib{background:#fff;border:1.5px solid var(–bd);border-radius:13px;display:flex;align-items:center;gap:9px;padding:9px 13px;margin-top:11px;box-shadow:0 2px 10px rgba(13,122,114,.07)}
.cib input{flex:1;border:none;outline:none;font-family:‘Plus Jakarta Sans’,sans-serif;font-size:13.5px;color:var(–tx)}
.cs2{background:var(–t);color:#fff;border:none;width:33px;height:33px;border-radius:9px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;transition:background .2s}
.cs2:hover{background:var(–td)}
.td{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(–tm);margin:0 2px;animation:bn .8s infinite}
.td:nth-child(2){animation-delay:.15s}.td:nth-child(3){animation-delay:.3s}
@keyframes bn{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}

/* ── COMMUTE ── */
.rc{background:linear-gradient(135deg,var(–td),var(–t));color:#fff;border-radius:15px;padding:19px 21px;border-bottom:3px solid var(–g)}
.rs{display:flex;align-items:center;gap:11px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.1)}
.rs:last-child{border-bottom:none}

/* ── MEALS ── */
.dc{border:1.5px solid var(–bd);border-radius:12px;overflow:hidden}
.dh{background:var(–t);color:#fff;padding:8px 10px;font-family:‘Playfair Display’,serif;font-size:12px;font-weight:700;text-align:center}
.ms2{padding:8px 10px;border-bottom:1px solid var(–bd);cursor:pointer;transition:background .15s}
.ms2:last-child{border-bottom:none}.ms2:hover{background:var(–tl)}
.ms2 .mt2{font-size:9px;text-transform:uppercase;letter-spacing:.8px;color:var(–mu);font-weight:700}
.ms2 .mn{font-size:12px;color:var(–tx);margin-top:1px;font-weight:500}
.ms2.empty .mn{color:var(–mu);font-style:italic}

/* ── MISC ── */
.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:13px}
.st{font-family:‘Playfair Display’,serif;font-size:16px;font-weight:800;color:var(–td)}
.mc2{border:1.5px solid var(–bd);border-radius:13px;padding:14px;display:flex;align-items:center;gap:12px;transition:all .2s}
.mc2:hover{border-color:var(–t);box-shadow:0 2px 10px rgba(13,122,114,.1)}
.mci{width:42px;height:42px;border-radius:11px;background:var(–tl);display:flex;align-items:center;justify-content:center;font-size:20px}
.ir{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid var(–bd)}
.ir:last-child{border-bottom:none}
.es{text-align:center;padding:28px 16px;color:var(–mu)}
.es .ei{font-size:34px;margin-bottom:8px}
.es p{font-size:13px}
.ps{background:#fff;border:1.5px solid var(–bd);border-radius:15px;padding:18px;margin-bottom:14px}
.ps h3{font-family:‘Playfair Display’,serif;font-size:14px;font-weight:700;color:var(–td);margin-bottom:12px;padding-bottom:9px;border-bottom:1px solid var(–bd)}

::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(–bd);border-radius:99px}

@media(max-width:900px){
#sb{transform:translateX(-100%)}#mn{margin-left:0}
.g4{grid-template-columns:1fr 1fr}.g3{grid-template-columns:1fr 1fr}.g2{grid-template-columns:1fr}
}

/* ── MOBILE NAV TOGGLE ── */
#ham{display:none;position:fixed;top:12px;left:14px;z-index:300;width:40px;height:40px;border-radius:10px;background:var(–td);border:none;cursor:pointer;flex-direction:column;align-items:center;justify-content:center;gap:5px;box-shadow:0 2px 10px rgba(10,74,69,.3)}
#ham span{display:block;width:20px;height:2px;background:#fff;border-radius:2px;transition:all .3s}
#sb-overlay{display:none;position:fixed;inset:0;background:rgba(10,74,69,.5);z-index:99;backdrop-filter:blur(2px)}
@media(max-width:900px){
#ham{display:flex}
#sb{transform:translateX(-100%);transition:transform .3s cubic-bezier(.4,0,.2,1);z-index:200}
#sb.open{transform:translateX(0)}
#sb-overlay.open{display:block}
#mn{margin-left:0}
.tb{padding-left:60px}
.g4{grid-template-columns:1fr 1fr}.g3{grid-template-columns:1fr 1fr}.g2{grid-template-columns:1fr}
#pg-chat{height:calc(100vh - 170px)}
body{padding-bottom:70px}
}
/* ── BOTTOM NAV (mobile) ── */
#bnav{display:none;position:fixed;bottom:0;left:0;right:0;background:var(–td);z-index:150;border-top:2px solid rgba(212,160,23,.3);padding:6px 0 env(safe-area-inset-bottom,6px)}
@media(max-width:900px){#bnav{display:flex}}
.bn-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:4px 2px;cursor:pointer;transition:all .2s;border-radius:8px;margin:0 2px;gap:2px}
.bn-item .bn-ico{font-size:20px;line-height:1}
.bn-item .bn-lbl{font-size:9px;color:rgba(255,255,255,.5);font-weight:600;letter-spacing:.2px}
.bn-item.active .bn-ico{filter:drop-shadow(0 0 4px rgba(212,160,23,.8))}
.bn-item.active .bn-lbl{color:var(–gl)}
/* ── SMOOTH PAGE TRANSITIONS ── */
.pg{animation:none}
.pg.slide-in{animation:slideIn .28s cubic-bezier(.4,0,.2,1)}
.pg.slide-out{animation:slideOut .22s cubic-bezier(.4,0,.2,1)}
@keyframes slideIn{from{opacity:0;transform:translateX(18px)}to{opacity:1;transform:translateX(0)}}
@keyframes slideOut{from{opacity:1;transform:translateX(0)}to{opacity:0;transform:translateX(-18px)}}
/* ── SCANNER MODAL ── */
#scan-modal{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:600;display:none;flex-direction:column;align-items:center;justify-content:center}
#scan-modal.open{display:flex}
.scan-box{background:#111;border-radius:20px;overflow:hidden;width:360px;max-width:96vw;position:relative}
.scan-header{background:var(–td);padding:16px 20px;display:flex;align-items:center;justify-content:space-between;border-bottom:2px solid var(–g)}
.scan-title{font-family:‘Playfair Display’,serif;font-size:17px;font-weight:800;color:#fff}
.scan-close{width:28px;height:28px;border-radius:50%;border:none;background:rgba(255,255,255,.15);color:#fff;cursor:pointer;font-size:14px;font-weight:700}
#scan-video{width:100%;height:280px;object-fit:cover;display:block}
.scan-overlay{position:absolute;top:52px;left:0;right:0;height:280px;pointer-events:none}
.scan-frame{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:220px;height:160px;border:2px solid var(–gl);border-radius:10px;box-shadow:0 0 0 9999px rgba(0,0,0,.45)}
.scan-line{position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(–gl),transparent);animation:scanLine 1.8s ease-in-out infinite}
@keyframes scanLine{0%,100%{top:0}50%{top:158px}}
.scan-footer{background:#111;padding:16px 18px}
.scan-status{text-align:center;font-size:13px;color:rgba(255,255,255,.7);margin-bottom:12px;min-height:20px}
.scan-result{background:rgba(255,255,255,.06);border-radius:11px;padding:14px;margin-bottom:12px;display:none}
.scan-result .sr-label{font-size:10px;text-transform:uppercase;letter-spacing:.8px;color:rgba(255,255,255,.4);margin-bottom:4px;font-weight:700}
.scan-result .sr-val{font-size:14px;color:#fff;font-weight:600}
.scan-actions{display:flex;gap:8px}
.scan-btn{flex:1;padding:10px;border-radius:9px;border:none;cursor:pointer;font-family:‘Plus Jakarta Sans’,sans-serif;font-size:13px;font-weight:700;transition:all .2s}
.scan-primary{background:var(–g);color:var(–td)}
.scan-primary:hover{background:var(–gl)}
.scan-secondary{background:rgba(255,255,255,.1);color:#fff}
.scan-secondary:hover{background:rgba(255,255,255,.18)}
#manual-exp-row{display:none;margin-top:10px}
</style>

</head>
<body>

<!-- Hamburger toggle -->

<button id="ham" onclick="toggleSidebar()" aria-label="Menu">
  <span></span><span></span><span></span>
</button>
<!-- Sidebar overlay for mobile -->
<div id="sb-overlay" onclick="closeSidebar()"></div>
<!-- Bottom nav (mobile) -->
<div id="bnav">
  <div class="bn-item active" onclick="nav('dashboard')" id="bn-dashboard"><div class="bn-ico">&#127968;</div><div class="bn-lbl">Home</div></div>
  <div class="bn-item" onclick="nav('bills')" id="bn-bills"><div class="bn-ico">&#128179;</div><div class="bn-lbl">Bills</div></div>
