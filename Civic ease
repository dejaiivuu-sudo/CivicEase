function rBudget(){
  const ts=Object.values(S.budgets).reduce((a,b)=>a+b.sp,0);
  const tb=Object.values(S.budgets).reduce((a,b)=>a+b.lim,0);
  document.getElementById('bu-inc').textContent=fmt(S.profile.income);
  document.getElementById('bu-tot').textContent=fmt(tb);
  document.getElementById('bu-sp').textContent=fmt(ts);
  document.getElementById('bu-rm').textContent=fmt((S.profile.income||0)-ts);
  const clrs={Groceries:'#0d7a72',Transport:'#d4a017',Healthcare:'#c0392b',Utilities:'#12a89d',Entertainment:'#8b6914',Education:'#0a4a45',Clothing:'#5a6a8a','Personal Care':'#6a4a7a',Other:'#5a8a86'};
  document.getElementById('cat-buds').innerHTML=Object.entries(S.budgets).map(([c,b])=>{
    const p=b.lim>0?Math.min(100,Math.round(b.sp/b.lim*100)):0;
    const cl=p>85?'#c0392b':p>60?'#d4a017':(clrs[c]||'#0d7a72');
    return`<div style="margin-bottom:13px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
        <span style="font-size:12.5px;font-weight:600">${c}</span>
        <div style="display:flex;align-items:center;gap:6px">
          <span style="font-size:11.5px;color:var(--mu)">${fmt(b.sp)} / ${fmt(b.lim)}</span>
          <span class="tag ${p>85?'tr':p>60?'ty':'tg'}">${p}%</span>
        </div>
      </div><div class="pb"><div class="pf" style="width:${p}%;background:${cl}"></div></div>
    </div>`;
  }).join('');
  document.getElementById('exp-list').innerHTML=S.expenses.length?[...S.expenses].reverse().slice(0,12).map(e=>
    `<div class="li2">
      <div class="lif"><strong>${e.name}</strong><span>${e.cat} · ${e.date}</span></div>
      <div style="display:flex;align-items:center;gap:7px;flex-shrink:0">
        <span class="tag tt">${e.cat}</span>
        <div class="lam" style="color:var(--r)">${fmt(e.amt)}</div>
        <button class="btn bd2 bsm" onclick="delExp(${e.id})">✕</button>
      </div>
    </div>`).join(''):'<div class="es"><div class="ei">💸</div><p>No expenses yet. Start logging!</p></div>';
}
function addExpense(){
  const name=document.getElementById('e-name').value.trim();
  const amt=parseFloat(document.getElementById('e-amt').value);
  const date=document.getElementById('e-date').value;
  const cat=document.getElementById('e-cat').value;
  if(!name)return toast('Please enter a description','err');
  if(!amt||amt<=0)return toast('Please enter a valid amount','err');
  if(!date)return toast('Please select a date','err');
  S.expenses.push({id:uid('e'),name,amt,date,cat});
  if(S.budgets[cat]){
    S.budgets[cat].sp+=amt;
    if(S.budgets[cat].sp>S.budgets[cat].lim)toast(`⚠️ Over ${cat} budget limit!`,'err');
  }
  save();closeM('m-exp');
  document.getElementById('e-name').value='';document.getElementById('e-amt').value='';
  rBudget();toast('Expense logged ✓','ok');
}
function delExp(id){
  const e=S.expenses.find(e=>e.id===id);
  if(e&&S.budgets[e.cat])S.budgets[e.cat].sp=Math.max(0,S.budgets[e.cat].sp-e.amt);
  S.expenses=S.expenses.filter(e=>e.id!==id);save();rBudget();
}
function saveBlim(){
  Object.keys(S.budgets).forEach(c=>{
    const el=document.getElementById('bl-'+c.replace(/[\s/]+/g,'-'));
    if(el){const v=parseFloat(el.value);if(v>=0)S.budgets[c].lim=v;}
  });
  save();closeM('m-blim');rBudget();toast('Budget limits updated ✓','ok');
}

