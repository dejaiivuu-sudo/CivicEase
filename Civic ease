function comTime(h){const hl=h.toLowerCase();if(hl.includes('portmore')||hl.includes('st. catherine'))return'40-55 min';if(hl.includes('spanish town'))return'35-50 min';if(hl.includes('kingston'))return'15-30 min';return'30-45 min';}
function comFare(m){if(!m||m.includes('Walk'))return'Free';if(m.includes('Express'))return'J$250-350';if(m.includes('JUTC'))return'J$100-180';return'J$120-200';}
function depTime(wt){if(!wt)return'7:00 AM';const[h,m]=wt.split(':').map(Number);const dep=h*60+m-45;const dh=Math.floor(dep/60),dm=dep%60;return`${dh%12||12}:${String(dm).padStart(2,'0')} ${dh<12?'AM':'PM'}`;}

function rCommute(){
  const p=S.profile;
  if(!p.home||!p.work){
    document.getElementById('rt-title').textContent='Route not configured';
    document.getElementById('rt-steps').innerHTML='<div style="color:rgba(255,255,255,.7);font-size:13px;padding:10px 0">Click "Update Route" to set up your daily commute.</div>';
    ['rt-time','rt-fare','rt-dep'].forEach(id=>document.getElementById(id).textContent='–');
  }else{
    document.getElementById('rt-title').textContent=`${p.home} → ${p.work}`;
    document.getElementById('rt-time').textContent=comTime(p.home);
    document.getElementById('rt-fare').textContent=comFare(p.transport);
    document.getElementById('rt-dep').textContent=depTime(p.wt);
    const mid=p.home.toLowerCase().includes('portmore')?'Half Way Tree':p.home.toLowerCase().includes('spanish town')?'Three Miles':'Cross Roads';
    const steps=[
      {ico:'🏠',txt:p.home,t:depTime(p.wt)},
      {ico:'🚌',txt:`Board ${p.transport} towards ${mid}`,t:''},
      {ico:'🔄',txt:`Transfer at ${mid}`,t:''},
      {ico:'🚌',txt:`Continue to ${p.work}`,t:''},
      {ico:'💼',txt:p.work,t:fmtT(p.wt)},
    ];
    document.getElementById('rt-steps').innerHTML=steps.map(s=>
      `<div class="rs"><span style="font-size:17px">${s.ico}</span>
       <div style="flex:1"><div style="font-size:13px;font-weight:600">${s.txt}</div></div>
       ${s.t?`<div style="font-size:11px;opacity:.65">${s.t}</div>`:''}</div>`).join('');
  }
  document.getElementById('com-tips').innerHTML=[
    {i:'⏰',t:'Leave earlier Mon & Fri',b:'Traffic is 20-30% heavier at week start and end.'},
    {i:'💰',t:'Consider a monthly pass',b:'Monthly passes save J$1,500-2,500 vs paying daily.'},
    {i:'🌧️',t:'Check the weather first',b:'Rain significantly increases commute times island-wide.'},
  ].map(x=>`<div style="display:flex;gap:10px;padding:11px 0;border-bottom:1px solid var(--bd)">
    <span style="font-size:18px">${x.i}</span>
    <div><div style="font-size:13px;font-weight:600;color:var(--td)">${x.t}</div>
    <div style="font-size:12px;color:var(--mu);margin-top:1px">${x.b}</div></div>
  </div>`).join('');
  document.getElementById('com-alts').innerHTML=p.home&&p.work?[
    {n:`Express Bus — ${p.home||'Home'} to ${p.work||'Work'}`,t:'Faster',f:'J$250-350',note:'Premium, usually air-conditioned'},
    {n:'Route Taxi direct (no transfer)',t:'Varies',f:'J$150-200',note:'More flexible timing'},
  ].map(r=>`<div class="li2">
    <div class="lic" style="background:var(--tl)">🗺️</div>
    <div class="lif"><strong>${r.n}</strong><span>${r.note}</span></div>
    <div style="text-align:right;flex-shrink:0"><div style="font-weight:700;font-size:13px">${r.t}</div><div style="font-size:11.5px;color:var(--mu)">${r.f}</div></div>
  </div>`).join(''):'<div class="es"><div class="ei">🗺️</div><p>Set up your route to see alternatives</p></div>';
}
function saveCom(){
  const h=document.getElementById('cm-home').value.trim(),w=document.getElementById('cm-work').value.trim();
  if(!h||!w)return toast('Please enter home and work locations','err');
  S.profile.home=h;S.profile.work=w;
  S.profile.wt=document.getElementById('cm-wt').value;
  S.profile.transport=document.getElementById('cm-tr').value;
  save();closeM('m-com');rCommute();toast('Commute route updated ✓','ok');
}

