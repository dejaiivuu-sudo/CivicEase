<div id="toast"></div>

<script>
// ════════════════════════════════════
// STORAGE
// ════════════════════════════════════
const SK='civicease_v3';
function save(){try{localStorage.setItem(SK,JSON.stringify(S))}catch(e){}}
function load(){try{const r=localStorage.getItem(SK);if(r)return JSON.parse(r)}catch(e){}return null}

const DEF={
  profile:{name:'',job:'',sector:'Public Sector',income:0,home:'',work:'',wt:'08:00',transport:'Bus / Route Taxi',cond:'',diet:''},
  bills:[],expenses:[],receipts:[],meds:[],items:[],chatHistory:[],onboarded:false,
  nextId:{b:1,e:1,r:1,m:1,i:1},
  budgets:{
    Groceries:{lim:20000,sp:0},Transport:{lim:8000,sp:0},Healthcare:{lim:10000,sp:0},
    Utilities:{lim:20000,sp:0},Entertainment:{lim:5000,sp:0},Education:{lim:10000,sp:0},
    Clothing:{lim:5000,sp:0},'Personal Care':{lim:4000,sp:0},Other:{lim:8000,sp:0}
  },
  meals:{Mon:{b:'',l:'',d:''},Tue:{b:'',l:'',d:''},Wed:{b:'',l:'',d:''},Thu:{b:'',l:'',d:''},Fri:{b:'',l:'',d:''},Sat:{b:'',l:'',d:''},Sun:{b:'',l:'',d:''}}
};

let S=load()||JSON.parse(JSON.stringify(DEF));
// Ensure all keys exist after potential version updates
if(!S.nextId)S.nextId={b:100,e:100,r:100,m:100,i:100};
if(!S.profile)S.profile={...DEF.profile};
if(!S.chatHistory)S.chatHistory=[];
if(!S.meals)S.meals=JSON.parse(JSON.stringify(DEF.meals));

// ════════════════════════════════════
// ONBOARDING
// ════════════════════════════════════
let obS=0;
function initOB(){
  // Build budget fields
  const cats=Object.keys(DEF.budgets);
  document.getElementById('ob-budget-fields').innerHTML=cats.map(c=>`
    <div class="fr" style="margin-bottom:0">
      <div class="fg" style="margin-bottom:9px">
        <label>${c}</label>
        <input type="number" id="ob-b-${c.replace(/[\s/]+/g,'-')}" placeholder="e.g. 15000" min="0" value="${S.budgets[c]?.lim||''}">
      </div>
    </div>`).join('');
  // Only skip onboarding if user has already completed it on THIS device
  if(S.onboarded && S.profile && S.profile.name){
    document.getElementById('ob').style.display='none';
    initApp();
  } else {
    // Always show onboarding from step 0 for new users
    obS=0;
    document.querySelectorAll('.ob-step').forEach(s=>s.classList.remove('active'));
    document.getElementById('os0').classList.add('active');
    updDots();
    document.getElementById('ob').style.display='flex';
  }
}
function obNext(){
  if(obS===1){
    const name=document.getElementById('ob-name').value.trim();
    if(!name)return toast('Please enter your name','err');
    const inc=parseFloat(document.getElementById('ob-inc').value);
    if(!inc||inc<=0)return toast('Please enter your monthly income','err');
    S.profile.name=name;S.profile.job=document.getElementById('ob-job').value.trim();
    S.profile.sector=document.getElementById('ob-sec').value;S.profile.income=inc;
  }
  if(obS===2){
    const h=document.getElementById('ob-home').value.trim(),w=document.getElementById('ob-work').value.trim();
    if(!h||!w)return toast('Please enter home and work locations','err');
    S.profile.home=h;S.profile.work=w;
    S.profile.wt=document.getElementById('ob-wt').value;
    S.profile.transport=document.getElementById('ob-tr').value;
  }
  if(obS===3){
    Object.keys(DEF.budgets).forEach(c=>{
      const el=document.getElementById('ob-b-'+c.replace(/[\s/]+/g,'-'));
      if(el){const v=parseFloat(el.value);if(v>0)S.budgets[c].lim=v;}
    });
  }
  if(obS<4){
    document.getElementById('os'+obS).classList.remove('active');
    obS++;
    document.getElementById('os'+obS).classList.add('active');
    updDots();
  }
}
function obPrev(){
  if(obS>0){
    document.getElementById('os'+obS).classList.remove('active');
    obS--;document.getElementById('os'+obS).classList.add('active');updDots();
  }
}
function updDots(){
  for(let i=0;i<5;i++){
    const d=document.getElementById('od'+i);
    d.className='od'+(i===obS?' active':i<obS?' done':'');
  }
}
function finishOB(){
  S.profile.cond=document.getElementById('ob-cond').value.trim();
  S.profile.diet=document.getElementById('ob-diet').value;
  S.onboarded=true;save();
  document.getElementById('ob').style.display='none';
  initApp();
}

// ════════════════════════════════════
// APP INIT
// ════════════════════════════════════
function initApp(){
  const now=new Date();
  document.getElementById('date-el').textContent=now.toLocaleDateString('en-JM',{weekday:'short',month:'long',day:'numeric'});
  updSidebar();
  // Set today default for all date inputs
  const today=now.toISOString().split('T')[0];
  ['b-due','e-date','r-date','it-exp'].forEach(id=>{const el=document.getElementById(id);if(el&&!el.value)el.value=today;});
  nav('dashboard');
}
function updSidebar(){
  const p=S.profile;
  const ini=p.name?p.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2):'?';
  document.getElementById('sb-av').textContent=ini;
  document.getElementById('sb-name').textContent=p.name||'Your Name';
  document.getElementById('sb-sec').textContent=p.sector||'Set up profile';
}

// ════════════════════════════════════
// NAVIGATION
// ════════════════════════════════════
const PM={
  dashboard:['Dashboard','Your daily overview'],bills:['Bill Payments','Manage your bills'],
  budget:['Budgeting','Track income & expenses'],receipts:['Receipts','Log and track spending'],
  commute:['Smart Commute','AI-powered route planning'],meds:['Medications','Track prescriptions'],
  expiry:['Expiry Tracker','Monitor pantry freshness'],meals:['Meal Planning','Weekly meals & shopping'],
  chat:['CivicAssist AI','Your personal AI assistant'],profile:['My Profile','Update your settings']
};
let _curPg='dashboard';
function nav(pg){
  const cur=document.getElementById('pg-'+_curPg);
  const next=document.getElementById('pg-'+pg);
  if(!next)return;
  // Close sidebar on mobile after nav
  closeSidebar();
  // Animate out current, in next
  if(cur&&cur!==next){
    cur.classList.add('slide-out');
    setTimeout(()=>{cur.classList.remove('active','slide-out');},180);
  }
  setTimeout(()=>{
    document.querySelectorAll('.pg').forEach(p=>{if(p!==next)p.classList.remove('active');});
    next.classList.add('active','slide-in');
    setTimeout(()=>next.classList.remove('slide-in'),300);
  },cur&&cur!==next?100:0);
  _curPg=pg;
  // Sidebar nav highlights
  document.querySelectorAll('.ni').forEach(n=>n.classList.remove('active'));
  document.querySelectorAll('.ni').forEach(n=>{if(n.getAttribute('onclick')?.includes("'"+pg+"'"))n.classList.add('active');});
  // Bottom nav highlights
  document.querySelectorAll('.bn-item').forEach(b=>b.classList.remove('active'));
  const bn=document.getElementById('bn-'+pg);if(bn)bn.classList.add('active');
  // Page title
  const[t,s]=PM[pg]||[pg,''];
  document.getElementById('pg-title').textContent=t;
  const h=new Date().getHours(),g=h<12?'Good morning':h<17?'Good afternoon':'Good evening';
  document.getElementById('pg-sub').textContent=pg==='dashboard'?`${g}, ${S.profile.name||'there'}`:s;
  renderPg(pg);
}
function renderPg(pg){
  const fn={dashboard:rDash,bills:rBills,budget:rBudget,receipts:rReceipts,commute:rCommute,meds:rMeds,expiry:rExpiry,meals:rMeals,profile:rProfile,
    chat:()=>{if(S.chatHistory.length>0)restoreChat();else initChat();}};
  if(fn[pg])fn[pg]();
}

// ════════════════════════════════════
// HELPERS
// ════════════════════════════════════
function openM(id){
  document.getElementById(id).classList.add('open');
  const today=new Date().toISOString().split('T')[0];
  ['b-due','e-date','r-date','it-exp'].forEach(fid=>{const el=document.getElementById(fid);if(el&&!el.value)el.value=today;});
  if(id==='m-com'){
    document.getElementById('cm-home').value=S.profile.home||'';
    document.getElementById('cm-work').value=S.profile.work||'';
    document.getElementById('cm-wt').value=S.profile.wt||'08:00';
    document.getElementById('cm-tr').value=S.profile.transport||'Bus / Route Taxi';
  }
  if(id==='m-blim'){
    document.getElementById('blim-fields').innerHTML=Object.keys(S.budgets).map(c=>`
      <div class="fg" style="margin-bottom:10px">
        <label>${c}</label>
        <input type="number" id="bl-${c.replace(/[\s/]+/g,'-')}" value="${S.budgets[c].lim}" min="0">
      </div>`).join('');
  }
}
function closeM(id){document.getElementById(id).classList.remove('open');}
function toast(msg,type=''){
  const t=document.getElementById('toast');
  t.textContent=msg;t.className='show '+type;
  clearTimeout(t._t);t._t=setTimeout(()=>t.className='',3200);
}
function fmt(n){return 'J$'+Number(n||0).toLocaleString();}
function days(d){return Math.ceil((new Date(d)-new Date(new Date().toDateString()))/86400000);}
function uid(k){const id=S.nextId[k]++;save();return id;}
function fmtT(t){if(!t)return'';const[h,m]=t.split(':').map(Number);return`${h%12||12}:${String(m).padStart(2,'0')} ${h<12?'AM':'PM'}`;}
function addH(t,h){const[hh,mm]=t.split(':').map(Number);return String((hh+h)%24).padStart(2,'0')+':'+String(mm).padStart(2,'0');}

// ════════════════════════════════════
// DASHBOARD
// ════════════════════════════════════
function rDash(){
  const p=S.profile;
  const h=new Date().getHours(),g=h<12?'Good morning':h<17?'Good afternoon':'Good evening';
  document.getElementById('d-greet').textContent=`${g}, ${p.name||'there'} 👋`;
  const ub=S.bills.filter(b=>!b.paid).length,pm=S.meds.filter(m=>!m.taken).length;
  document.getElementById('d-sum').textContent=`You have ${ub} unpaid bill${ub!==1?'s':''} and ${pm} pending medication dose${pm!==1?'s':''} today.`;
  document.getElementById('d-inc').textContent=fmt(p.income);
  const ts=Object.values(S.budgets).reduce((a,b)=>a+b.sp,0);
  document.getElementById('d-sp').textContent=fmt(ts);
  document.getElementById('d-bi').textContent=ub;
  document.getElementById('d-me').textContent=pm;

  // Budget bars
  const top=Object.entries(S.budgets).filter(([,b])=>b.lim>0).sort(([,a],[,b])=>b.sp-a.sp).slice(0,4);
  const clrs=['#0d7a72','#d4a017','#c0392b','#12a89d'];
  document.getElementById('d-bars').innerHTML=top.length?top.map(([c,b],i)=>{
    const p=b.lim>0?Math.min(100,Math.round(b.sp/b.lim*100)):0;
    const cl=p>85?'#c0392b':p>60?'#d4a017':clrs[i];
    return`<div style="margin-bottom:11px">
      <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px">
        <span style="font-weight:600">${c}</span><span style="color:var(--mu)">${fmt(b.sp)} / ${fmt(b.lim)}</span>
      </div><div class="pb"><div class="pf" style="width:${p}%;background:${cl}"></div></div>
    </div>`;
  }).join(''):'<div class="es" style="padding:16px 0"><div class="ei">📊</div><p>Add expenses to see budget overview</p></div>';

  // Upcoming bills
  const upcoming=S.bills.filter(b=>!b.paid).sort((a,b)=>new Date(a.due)-new Date(b.due)).slice(0,3);
  document.getElementById('d-ubills').innerHTML=upcoming.length?upcoming.map(b=>{
    const d=days(b.due);
    return`<div class="li2">
      <div class="lic" style="background:var(--tl)">${bIco(b.cat)}</div>
      <div class="lif"><strong>${b.name}</strong><span>${d<0?Math.abs(d)+'d overdue':d===0?'Due today':'Due in '+d+'d'}</span></div>
      <div class="lam" style="color:${d<0?'var(--r)':'var(--tx)'}">${fmt(b.amt)}</div>
    </div>`;
  }).join(''):'<div class="es" style="padding:14px 0"><div class="ei">🎉</div><p>No unpaid bills!</p></div>';

  // Commute
  if(p.home&&p.work){
    document.getElementById('d-commute').innerHTML=`
      <div style="display:flex;align-items:center;gap:11px;padding:11px;background:var(--td);border-radius:11px;color:#fff;border-left:4px solid var(--g)">
        <span style="font-size:22px">🚌</span>
        <div><div style="font-size:13px;font-weight:600">${p.home} → ${p.work}</div>
        <div style="font-size:11.5px;opacity:.7;margin-top:2px">Depart by ${depTime(p.wt)} · ${comTime(p.home)} · ${comFare(p.transport)}</div></div>
      </div>`;
  }else{
    document.getElementById('d-commute').innerHTML=`<div class="es" style="padding:14px 0"><div class="ei">🚌</div><p><a href="#" onclick="nav('profile')" style="color:var(--t)">Set up your commute</a> in Profile</p></div>`;
  }

  // Expiry
  const exp=S.items.filter(i=>days(i.exp)<=5).sort((a,b)=>days(a.exp)-days(b.exp));
  document.getElementById('d-expiry').innerHTML=exp.length?exp.map(i=>{
    const d=days(i.exp);
    const[cl,bg]=d<0?['var(--r)','var(--rp)']:d<=2?['#b45309','#fff7ed']:['#7a5800','var(--gp)'];
    return`<div class="li2"><div class="lif"><strong>${i.name}</strong><span>${i.cat}</span></div>
      <span class="tag" style="background:${bg};color:${cl}">${d<0?'Expired':d===0?'Today':d+'d left'}</span></div>`;
  }).join(''):'<div class="es" style="padding:14px 0"><div class="ei">✅</div><p>All items fresh</p></div>';
}

// ════════════════════════════════════
// BILLS
// ════════════════════════════════════
function bIco(c){const m={Electricity:'⚡',Water:'💧',Internet:'📶',Phone:'📱','Rent / Mortgage':'🏠',Insurance:'🛡️','Loan Repayment':'🏦','Cable / Streaming':'📺',Other:'📄'};return m[c]||'📄';}
function rBills(){
  const up=S.bills.filter(b=>!b.paid),pd=S.bills.filter(b=>b.paid);
  document.getElementById('bi-due').textContent=fmt(up.reduce((s,b)=>s+b.amt,0));
  document.getElementById('bi-pd').textContent=fmt(pd.reduce((s,b)=>s+b.amt,0));
  document.getElementById('bi-ov').textContent=up.filter(b=>days(b.due)<0).length;
  document.getElementById('bi-up').textContent=up.filter(b=>{const d=days(b.due);return d>=0&&d<=7;}).length;
  const sorted=[...S.bills].sort((a,b)=>a.paid!==b.paid?a.paid?1:-1:new Date(a.due)-new Date(b.due));
  document.getElementById('bills-list').innerHTML=sorted.length?sorted.map(b=>{
    const d=days(b.due);
    const st=b.paid?'<span class="tag tg">✓ Paid</span>':d<0?`<span class="tag tr">Overdue ${Math.abs(d)}d</span>`:d<=3?'<span class="tag ty">Due Soon</span>':'<span class="tag tt">Upcoming</span>';
    return`<div class="li2">
      <div class="lic" style="background:var(--tl)">${bIco(b.cat)}</div>
      <div class="lif"><strong>${b.name}</strong><span>${b.cat} · Due ${b.due}</span></div>
      <div style="display:flex;align-items:center;gap:7px;flex-shrink:0">
        ${st}<div class="lam">${fmt(b.amt)}</div>
        ${!b.paid?`<button class="btn bp bsm" onclick="payBill(${b.id})">Pay Now</button>`:`<button class="btn bo bsm" onclick="unpayBill(${b.id})">Undo</button>`}
        <button class="btn bd2 bsm" onclick="delBill(${b.id})">✕</button>
      </div>
    </div>`;
  }).join(''):'<div class="es"><div class="ei">💳</div><p>No bills yet. Click "+ Add Bill" to start.</p></div>';
}
function addBill(){
  const name=document.getElementById('b-name').value.trim();
  const amt=parseFloat(document.getElementById('b-amt').value);
  const due=document.getElementById('b-due').value;
  const cat=document.getElementById('b-cat').value;
  if(!name)return toast('Please enter a bill name','err');
  if(!amt||amt<=0)return toast('Please enter a valid amount','err');
  if(!due)return toast('Please select a due date','err');
  S.bills.push({id:uid('b'),name,amt,due,cat,paid:false});
  save();closeM('m-bill');
  document.getElementById('b-name').value='';document.getElementById('b-amt').value='';
  rBills();toast('Bill added ✓','ok');
}
function payBill(id){const b=S.bills.find(b=>b.id===id);if(!b)return;b.paid=true;save();rBills();rDash();toast(`${b.name} marked as paid ✓`,'ok');}
function unpayBill(id){const b=S.bills.find(b=>b.id===id);if(b){b.paid=false;save();rBills();}}
function delBill(id){S.bills=S.bills.filter(b=>b.id!==id);save();rBills();toast('Bill removed','');}

