function rMeds(){
  document.getElementById('med-cards').innerHTML=S.meds.length?S.meds.map(m=>
    `<div class="mc2">
      <div class="mci">💊</div>
      <div style="flex:1;min-width:0">
        <div style="font-family:'Playfair Display',serif;font-size:14px;font-weight:700;color:var(--td);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${m.name}</div>
        <div style="font-size:11.5px;color:var(--mu);margin-top:2px">${m.dose} · ${m.freq}</div>
        ${m.cond?`<div style="font-size:11px;color:var(--t);margin-top:2px;font-weight:600">${m.cond}</div>`:''}
        ${m.stk?`<div style="font-size:11px;color:${m.stk<7?'var(--r)':'var(--mu)'};margin-top:2px">${m.stk} pills left${m.stk<7?' ⚠️ refill soon':''}</div>`:''}
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0">
        <span class="tag ${m.taken?'tg':'ty'}">${m.taken?'✓ Taken':'Pending'}</span>
        <button class="btn bd2 bsm" onclick="delMed(${m.id})">Remove</button>
      </div>
    </div>`).join(''):'<div class="es" style="grid-column:1/-1"><div class="ei">💊</div><p>No medications added yet</p></div>';
  // Build schedule
  const doses=[];
  S.meds.forEach(m=>{
    const times=m.freq==='Twice daily'?[m.time,addH(m.time,12)]:m.freq==='Three times daily'?[m.time,addH(m.time,6),addH(m.time,12)]:m.freq==='Every 8 hours'?[m.time,addH(m.time,8),addH(m.time,16)]:[m.time];
    times.forEach(t=>doses.push({...m,sched:t}));
  });
  doses.sort((a,b)=>a.sched.localeCompare(b.sched));
  document.getElementById('med-sched').innerHTML=doses.length?doses.map(d=>
    `<div class="li2">
      <div class="lic" style="background:var(--gp)">⏰</div>
      <div class="lif"><strong>${d.name}</strong><span>${d.dose}${d.doc?' · '+d.doc:''}</span></div>
      <div style="display:flex;align-items:center;gap:8px;flex-shrink:0">
        <span style="font-family:'Playfair Display',serif;font-weight:700;font-size:14px">${fmtT(d.sched)}</span>
        <button class="btn bsm ${d.taken?'bo':'bp'}" onclick="togMed(${d.id})">${d.taken?'✓ Taken':'Mark Taken'}</button>
      </div>
    </div>`).join(''):'<div class="es"><div class="ei">⏰</div><p>No doses scheduled</p></div>';
}
function addMed(){
  const name=document.getElementById('md-name').value.trim();
  const dose=document.getElementById('md-dose').value.trim();
  if(!name)return toast('Please enter the medication name','err');
  if(!dose)return toast('Please enter the dosage','err');
  const freq=document.getElementById('md-freq').value;
  const time=document.getElementById('md-time').value;
  const cond=document.getElementById('md-cond').value.trim();
  const doc=document.getElementById('md-doc').value.trim();
  const stk=parseInt(document.getElementById('md-stk').value)||0;
  S.meds.push({id:uid('m'),name,dose,freq,time,cond,doc,stk,taken:false});
  save();closeM('m-med');
  ['md-name','md-dose','md-cond','md-doc','md-stk'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('md-time').value='08:00';
  rMeds();toast('Medication added ✓','ok');
}
function togMed(id){
  const m=S.meds.find(m=>m.id===id);if(!m)return;
  m.taken=!m.taken;if(m.taken&&m.stk>0)m.stk--;
  save();rMeds();if(m.taken)toast(`${m.name} marked as taken ✓`,'ok');
}
function delMed(id){S.meds=S.meds.filter(m=>m.id!==id);save();rMeds();toast('Medication removed','');}

